SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SEU_SERVICE_ROLE_KEY
APP_PROJECT_CODE=PEOCON
APP_PROJECT_NAME=Projeto PEOCON
SUPABASE_PROJECTS_TABLE=projects
SUPABASE_LANCAMENTOS_TABLE=lancamentos
SUPABASE_TOPICOS_TABLE=topicos
SUPABASE_APP_CONFIG_TABLE=app_config
SUPABASE_AUTH_SESSIONS_TABLE=auth_sessions
SUPABASE_AUDIT_LOG_TABLE=audit_log
SUPABASE_APP_USERS_TABLE=app_users
SUPABASE_PROJECT_MEMBERSHIPS_TABLE=project_memberships
SUPABASE_DEPARTMENTS_TABLE=departments
# APP_LOGIN_USERS_JSON aceita apenas passwordHash PBKDF2.
APP_LOGIN_USERS_JSON=[{"username":"PEOCON","passwordHash":"pbkdf2$sha256$310000$SALT_PEOCON$HASH_PEOCON","role":"admin","allowedProjects":["PEOCON"],"defaultProjectCode":"PEOCON"},{"username":"FELLOW","passwordHash":"pbkdf2$sha256$310000$SALT_FELLOW$HASH_FELLOW","role":"admin","allowedProjects":["FELLOW"],"defaultProjectCode":"FELLOW"},{"username":"Cesar1014","passwordHash":"pbkdf2$sha256$310000$SALT_CESAR$HASH_CESAR","role":"admin","allowedProjects":["PEOCON","FELLOW"],"defaultProjectCode":"PEOCON"}]
# APP_LOGIN_USER + APP_LOGIN_PASSWORD sao legados e bloqueados em producao.
AUTH_TOKEN_SECRET=SUBSTITUA_POR_UM_SEGREDO_LONGO_E_ALEATORIO_COM_32_OU_MAIS_CARACTERES
# Em dev, fallback temporario so com ALLOW_INSECURE_DEV_AUTH_SECRET=true
ALLOW_INSECURE_DEV_AUTH_SECRET=false
AUTH_SESSION_TTL_MS=43200000
AUTH_MAX_ACTIVE_SESSIONS=2000
LOGIN_RATE_WINDOW_MS=600000
LOGIN_RATE_MAX_ATTEMPTS=8
LOGIN_RATE_MAX_ATTEMPTS_PER_USER=8
LOGIN_RATE_GLOBAL_WINDOW_MS=600000
LOGIN_RATE_MAX_ATTEMPTS_GLOBAL=100
LOGIN_RATE_MAX_TRACKED_KEYS=5000
PDF_EXPORT_MAX_ITEMS=1200
PDF_TEXT_MAX_CHARS=180
TRUST_PROXY=0
